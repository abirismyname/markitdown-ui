<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Allows the app to load Sparkle.framework even though it is signed by a
	  different team than the main executable. Without this, the hardened
	  runtime blocks third-party dynamic libraries when ENABLE_CODE_SIGNING=true.
	-->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
</dict>
</plist>
